# Music API environment variables

# Port to run on (default: 7979)
MUSIC_API_PORT=7979

# Host to bind (default: 0.0.0.0)
MUSIC_API_HOST=0.0.0.0

# Workers for production (default: 1)
MUSIC_API_WORKERS=2

# CORS allowed origins — comma separated
# Leave empty to allow all origins (local dev only)
# Example for production: CORS_ORIGINS=https://barztify.yourdomain.com
CORS_ORIGINS=
